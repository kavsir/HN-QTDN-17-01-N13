<odoo>
    <data noupdate="1">
        <record id="rule_project_cong_viec_user" model="ir.rule">
            <field name="name">Nhân viên: Chỉ xem việc được giao</field>
            <field name="model_id" ref="model_project_cong_viec"/>
            <field name="domain_force">[('nhan_vien_thuc_hien_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_project_cong_viec_manager" model="ir.rule">
            <field name="name">Trưởng phòng: Quản lý công việc phòng ban</field>
            <field name="model_id" ref="model_project_cong_viec"/>
            <field name="domain_force">[('nhan_vien_thuc_hien_id.don_vi_id.nhan_vien_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_manager'))]"/>
        </record>

        <record id="rule_project_cong_viec_admin" model="ir.rule">
            <field name="name">Admin: Toàn quyền công việc</field>
            <field name="model_id" ref="model_project_cong_viec"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_admin'))]"/>
        </record>
    </data>
</odoo>