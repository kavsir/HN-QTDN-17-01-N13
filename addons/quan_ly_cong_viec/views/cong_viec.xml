<odoo>
    <!-- ==================== BỔ SUNG: VIEWS CHO DỰ ÁN (project.du_an) ==================== -->
    <record id="view_project_du_an_tree" model="ir.ui.view">
        <field name="name">project.du_an.tree</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <tree string="Danh sách dự án" decoration-danger="so_viec_qua_han &gt; 0">
                <field name="ten_du_an"/>
                <field name="don_vi_id"/>
                <field name="nguoi_phu_trach_id"/>
                <field name="han_chot"/>
                <field name="so_luong_cong_viec"/>
                <field name="so_viec_qua_han"/>
                <field name="ty_le_hoan_thanh" widget="progressbar"/>
                <field name="trang_thai" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_project_du_an_form" model="ir.ui.view">
        <field name="name">project.du_an.form</field>
        <field name="model">project.du_an</field>
        <field name="arch" type="xml">
            <form string="Thông tin dự án">
                <header>
                    <field name="trang_thai" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="ten_du_an" placeholder="Tên dự án..."/></h1>
                    </div>
                    <group>
                        <group string="Phụ trách">
                            <field name="don_vi_id"/>
                            <field name="nguoi_phu_trach_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Thời gian &amp; Tiến độ tổng">
                            <field name="ngay_bat_dau"/>
                            <field name="han_chot"/>
                            <field name="so_luong_cong_viec"/>
                            <field name="so_viec_qua_han"/>
                            <field name="ty_le_hoan_thanh" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="mo_ta"/>
                        </page>
                        <page string="Danh sách công việc">
                            <field name="cong_viec_ids">
                                <tree editable="bottom">
                                    <field name="ten_cong_viec"/>
                                    <field name="nhan_vien_thuc_hien_id"/>
                                    <field name="han_chot"/>
                                    <field name="tien_do_phan_tram" widget="progressbar"/>
                                    <field name="trang_thai_cong_viec"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project_du_an" model="ir.actions.act_window">
        <field name="name">Dự án</field>
        <field name="res_model">project.du_an</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ==================== BỔ SUNG: DASHBOARD CẢNH BÁO QUÁ TẢI NHÂN VIÊN ==================== -->
    <record id="view_nhan_vien_qua_tai_tree" model="ir.ui.view">
        <field name="name">nhan_vien.qua.tai.tree</field>
        <field name="model">nhan_vien</field>
        <field name="arch" type="xml">
            <tree string="Cảnh báo quá tải nhân viên" decoration-danger="canh_bao_qua_tai == True">
                <field name="ho_va_ten"/>
                <field name="don_vi_id"/>
                <field name="chuc_vu_id"/>
                <field name="so_cong_viec_dang_xu_ly"/>
                <field name="so_cong_viec_qua_han"/>
                <field name="canh_bao_qua_tai" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="action_nhan_vien_qua_tai" model="ir.actions.act_window">
        <field name="name">Cảnh báo quá tải nhân viên</field>
        <field name="res_model">nhan_vien</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_nhan_vien_qua_tai_tree"/>
        <field name="domain">[('trang_thai_lam_viec', '=', 'dang_lam')]</field>
        <field name="context">{'search_default_qua_tai': 1}</field>
    </record>

    <record id="view_project_cong_viec_tree" model="ir.ui.view">
        <field name="name">project.cong.viec.tree</field>
        <field name="model">project.cong.viec</field>
        <field name="arch" type="xml">
            <tree string="Danh sách công việc" 
                  decoration-danger="han_chot &lt; current_date and trang_thai_cong_viec != 'hoan_thanh'" 
                  decoration-success="trang_thai_cong_viec == 'hoan_thanh'" 
                  decoration-muted="trang_thai_cong_viec == 'huy'">
                <field name="ten_cong_viec"/>
                <field name="loai_cong_viec" optional="show"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="han_chot"/>
                <field name="tien_do_phan_tram" widget="progressbar"/>
                <field name="do_uu_tien" widget="priority" optional="show"/>
                <field name="trang_thai_cong_viec" widget="badge" 
                       decoration-success="trang_thai_cong_viec == 'hoan_thanh'" 
                       decoration-info="trang_thai_cong_viec == 'dang_lam'"
                       decoration-danger="trang_thai_cong_viec == 'huy'"
                       decoration-muted="trang_thai_cong_viec == 'chua_lam'"/>
            </tree>
        </field>
    </record>

    <record id="view_project_cong_viec_kanban" model="ir.ui.view">
        <field name="name">project.cong.viec.kanban</field>
        <field name="model">project.cong.viec</field>
        <field name="arch" type="xml">
            <!-- FIX: bỏ default_group_by="trang_thai_cong_viec" - trước đây
                 Kanban tự nhóm theo trạng thái, khiến task vừa hoàn thành bị
                 dời sang cột khác (thường nằm ngoài màn hình), gây cảm giác
                 "biến mất" khỏi danh sách đang xem. Giờ Kanban hiển thị TẤT
                 CẢ task chung 1 danh sách; trạng thái thể hiện bằng badge màu
                 ngay trên card (giữ được cột riêng thể hiện trạng thái, không
                 cần group by để phân biệt). Người dùng vẫn có thể tự chọn
                 "Group By > Trạng thái" trong ô tìm kiếm nếu muốn xem theo cột. -->
            <kanban class="o_kanban_small_column">
                <field name="id"/>
                <field name="ten_cong_viec"/>
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="han_chot"/>
                <field name="do_uu_tien"/>
                <field name="tien_do_phan_tram"/>
                <field name="trang_thai_cong_viec"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click d-flex flex-column justify-content-between p-3" style="border-radius: 6px; margin-bottom: 8px;">
                            <div>
                                <div class="d-flex justify-content-between align-items-start">
                                    <strong class="o_kanban_record_title" style="font-size: 14px; color: #1F2937;">
                                        <field name="ten_cong_viec"/>
                                    </strong>
                                    <span t-attf-class="badge badge-pill #{record.trang_thai_cong_viec.raw_value == 'hoan_thanh' ? 'badge-success' : record.trang_thai_cong_viec.raw_value == 'huy' ? 'badge-secondary' : record.trang_thai_cong_viec.raw_value == 'dang_lam' ? 'badge-info' : 'badge-light'}">
                                        <field name="trang_thai_cong_viec"/>
                                    </span>
                                </div>
                                <div class="text-muted" style="font-size: 12px; margin-top: 4px;">
                                    Người làm: <span style="font-weight: 500; color: #4B5563;"><field name="nhan_vien_thuc_hien_id"/></span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom d-flex justify-content-between align-items-center mt-3 pt-2" style="border-top: 1px solid #E5E7EB;">
                                <div class="oe_kanban_bottom_left">
                                    <field name="do_uu_tien" widget="priority"/>
                                </div>
                                <div class="oe_kanban_bottom_right d-flex align-items-center">
                                    <span class="text-muted" style="font-size: 12px; margin-right: 6px;">
                                        <i class="fa fa-calendar" title="Hạn chót" aria-label="Hạn chót"/> <field name="han_chot"/>
                                    </span>
                                    <span class="badge badge-pill badge-primary"><field name="tien_do_phan_tram"/>%</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_project_cong_viec_form" model="ir.ui.view">
        <field name="name">project.cong.viec.form</field>
        <field name="model">project.cong.viec</field>
        <field name="arch" type="xml">
            <form string="Thông tin công việc">
                <header>
                    <field name="trang_thai_cong_viec" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="ten_cong_viec" placeholder="Tên đầu việc cần làm..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Phân công &amp; Lịch trình">
                            <field name="nhan_vien_thuc_hien_id" options="{'no_create': True}"/>
                            <field name="du_an_id" options="{'no_create': True}"/>
                            <field name="loai_cong_viec"/>
                            <field name="ngay_bat_dau"/>
                            <field name="han_chot"/>
                        </group>
                        <group string="Tiến độ thực hiện">
                            <field name="do_uu_tien" widget="priority"/>
                            <field name="tien_do_phan_tram"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Nội dung &amp; Kết quả">
                            <field name="ghi_chu" placeholder="Ghi chú lại nội dung đã trao đổi với khách hàng..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_project_cong_viec_graph" model="ir.ui.view">
        <field name="name">project.cong.viec.graph</field>
        <field name="model">project.cong.viec</field>
        <field name="arch" type="xml">
            <!-- Vẽ biểu đồ cột thống kê công việc theo từng nhân viên và trạng thái -->
            <graph string="Thống kê Hiệu suất Công việc" type="bar">
                <field name="nhan_vien_thuc_hien_id"/>
                <field name="trang_thai_cong_viec"/>
            </graph>
        </field>
    </record>

    <!-- BỔ SUNG: Pivot thống kê công việc - dùng cho Dashboard quản lý -->
    <record id="view_project_cong_viec_pivot" model="ir.ui.view">
        <field name="name">project.cong.viec.pivot</field>
        <field name="model">project.cong.viec</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê Quản lý Công việc">
                <field name="nhan_vien_thuc_hien_id" type="row"/>
                <field name="loai_cong_viec" type="row"/>
                <field name="trang_thai_cong_viec" type="col"/>
                <field name="tien_do_phan_tram" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_project_cong_viec_dashboard" model="ir.actions.act_window">
        <field name="name">Thống kê quản lý công việc</field>
        <field name="res_model">project.cong.viec</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="action_project_cong_viec" model="ir.actions.act_window">
        <field name="name">Công việc chăm sóc</field>
        <field name="res_model">project.cong.viec</field>
        <!-- FIX: đổi 'tree' lên đầu làm view mặc định. Trước đây 'kanban' đứng
             đầu + kanban có default_group_by="trang_thai_cong_viec" khiến task
             vừa chuyển "Hoàn thành" bị dời sang cột kanban khác, cảm giác như
             "biến mất" khỏi danh sách đang xem. Tree đã có cột "Trạng thái"
             riêng (badge màu), task hoàn thành vẫn nằm nguyên trong danh sách,
             chỉ đổi màu badge - không còn bị dời/ẩn đi đâu cả. -->
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
    </record>

    <menuitem id="menu_project_root" name="Quản lý công việc" sequence="15"/>
    <menuitem id="menu_project_du_an" name="Dự án" parent="menu_project_root" action="action_project_du_an" sequence="1"/>
    <menuitem id="menu_project_task" name="Danh sách công việc" parent="menu_project_root" action="action_project_cong_viec" sequence="2"/>
    <menuitem id="menu_project_qua_tai" name="Cảnh báo quá tải nhân viên" parent="menu_project_root" action="action_nhan_vien_qua_tai" sequence="3"/>
    <menuitem id="menu_project_dashboard" name="Thống kê công việc" parent="menu_project_root" action="action_project_cong_viec_dashboard" sequence="4"/>
</odoo>