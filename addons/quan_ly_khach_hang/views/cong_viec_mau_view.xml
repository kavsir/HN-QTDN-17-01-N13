<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cong_viec_mau_tree" model="ir.ui.view">
        <field name="name">cong.viec.mau.tree</field>
        <field name="model">cong_viec_mau</field>
        <field name="arch" type="xml">
            <tree string="Cấu hình Checklist Mẫu" editable="bottom">
                <field name="name"/>
                <field name="loai_cong_viec"/>
                <field name="don_vi_thuc_hien_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="so_ngay_hoan_thanh"/>
            </tree>
        </field>
    </record>

    <record id="action_cong_viec_mau" model="ir.actions.act_window">
        <field name="name">Cấu hình Checklist Mẫu Dự Án</field>
        <field name="res_model">cong_viec_mau</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có cấu hình mẫu công việc nào!
            </p><p>
                Tạo các đầu việc mẫu tại đây. Khi cơ hội CRM chuyển sang "Thành công", hệ thống sẽ tự động sinh các đầu việc này giao cho phòng ban phụ trách.
            </p>
        </field>
    </record>

    <menuitem id="menu_config_cong_viec_mau"
              name="Cấu hình Checklist Mẫu"
              parent="quan_ly_cong_viec.menu_project_root"
              action="action_cong_viec_mau"
              sequence="100"/>
</odoo>