<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Nhân viên kinh doanh: chỉ thấy cơ hội mình được phân công phụ trách -->
        <record id="rule_co_hoi_user" model="ir.rule">
            <field name="name">Nhân viên: Chỉ xem cơ hội mình phụ trách</field>
            <field name="model_id" ref="model_crm_co_hoi"/>
            <field name="domain_force">[('nhan_vien_phu_trach_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Trưởng phòng kinh doanh: chỉ thấy cơ hội của nhân viên thuộc phòng ban mình -->
        <record id="rule_co_hoi_manager" model="ir.rule">
            <field name="name">Trưởng phòng: Quản lý cơ hội theo phòng ban</field>
            <field name="model_id" ref="model_crm_co_hoi"/>
            <field name="domain_force">[('don_vi_id.nhan_vien_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Admin / BGĐ: toàn quyền, xem được mọi cơ hội của mọi phòng ban -->
        <record id="rule_co_hoi_admin" model="ir.rule">
            <field name="name">Admin: Toàn quyền cơ hội kinh doanh</field>
            <field name="model_id" ref="model_crm_co_hoi"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_admin'))]"/>
        </record>

        <!-- Danh mục mẫu công việc (checklist chuẩn): chỉ Trưởng phòng/Admin được sửa,
             nhân viên thường chỉ đọc để hiểu quy trình -->
        <record id="rule_cong_viec_mau_user_readonly" model="ir.rule">
            <field name="name">Nhân viên: Chỉ đọc danh mục mẫu công việc</field>
            <field name="model_id" ref="model_cong_viec_mau"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('nhan_su.group_nhan_su_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
