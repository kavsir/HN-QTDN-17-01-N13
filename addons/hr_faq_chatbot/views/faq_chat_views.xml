<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_faq_chat_log_tree" model="ir.ui.view">
        <field name="name">hr.faq.chat.log.tree</field>
        <field name="model">hr.faq.chat.log</field>
        <field name="arch" type="xml">
            <tree string="Lịch sử hỏi đáp" create="false" edit="false">
                <field name="create_date" string="Thời gian"/>
                <field name="employee_id"/>
                <field name="question"/>
                <field name="found_answer" string="Có nguồn"/>
                <field name="response_time_ms" string="Thời gian phản hồi (ms)"/>
            </tree>
        </field>
    </record>

    <record id="view_hr_faq_chat_log_form" model="ir.ui.view">
        <field name="name">hr.faq.chat.log.form</field>
        <field name="model">hr.faq.chat.log</field>
        <field name="arch" type="xml">
            <form string="Chi tiết hỏi đáp" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="found_answer" readonly="1"/>
                            <field name="response_time_ms" readonly="1"/>
                        </group>
                    </group>
                    <group string="Câu hỏi đầu vào">
                        <field name="question" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Câu trả lời từ Trợ lý (RAG)">
                        <field name="answer" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Nguồn tài liệu trích dẫn">
                        <field name="sources" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_faq_chat_log" model="ir.actions.act_window">
        <field name="name">Lịch sử hỏi đáp</field>
        <field name="res_model">hr.faq.chat.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_hr_faq_chatbot_client" model="ir.actions.client">
        <field name="name">Trợ lý nội quy</field>
        <field name="tag">hr_faq_chatbot.chat_action</field>
    </record>

    <menuitem id="menu_hr_faq_chatbot_root"
              name="Trợ lý nội quy"
              parent="nhan_su.menu_root" 
              sequence="90"/>

    <menuitem id="menu_hr_faq_chatbot_chat"
              name="Hỏi đáp"
              parent="menu_hr_faq_chatbot_root"
              action="action_hr_faq_chatbot_client"
              sequence="10"/>

    <menuitem id="menu_hr_faq_chatbot_log"
              name="Lịch sử hỏi đáp"
              parent="menu_hr_faq_chatbot_root"
              action="action_hr_faq_chat_log"
              groups="hr.group_hr_manager"
              sequence="20"/>

    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
    </record>

    <record id="quan_ly_van_ban.menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
    </record>

</odoo>