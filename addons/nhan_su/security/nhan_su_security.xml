<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_nhan_su" model="ir.module.category">
            <field name="name">Quản lý Nhân sự</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_nhan_su_user" model="res.groups">
            <field name="name">Nhân viên</field>
            <field name="category_id" ref="module_category_nhan_su"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_nhan_su_manager" model="res.groups">
            <field name="name">Trưởng phòng</field>
            <field name="category_id" ref="module_category_nhan_su"/>
            <field name="implied_ids" eval="[(4, ref('group_nhan_su_user'))]"/>
        </record>

        <record id="group_nhan_su_admin" model="res.groups">
            <field name="name">Quản trị viên (HR / BGĐ)</field>
            <field name="category_id" ref="module_category_nhan_su"/>
            <field name="implied_ids" eval="[(4, ref('group_nhan_su_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_nhan_vien_personal" model="ir.rule">
            <field name="name">Nhân viên: Chỉ xem hồ sơ cá nhân</field>
            <field name="model_id" ref="model_nhan_vien"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nhan_su_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_nhan_vien_manager" model="ir.rule">
            <field name="name">Trưởng phòng: Quản lý phòng ban</field>
            <field name="model_id" ref="model_nhan_vien"/>
            <field name="domain_force">[('don_vi_id.nhan_vien_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nhan_su_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_nhan_vien_admin" model="ir.rule">
            <field name="name">Admin: Toàn quyền hệ thống</field>
            <field name="model_id" ref="model_nhan_vien"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_nhan_su_admin'))]"/>
        </record>
    </data>
</odoo>