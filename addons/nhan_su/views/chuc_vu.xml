<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_chuc_vu_form" model="ir.ui.view">
            <field name="name">chuc_vu.form</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px; font-weight: bold; margin-bottom: 10px;">CHỨC VỤ</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ma_chuc_vu"/>
                            <field name="ten_chuc_vu"/>
                            <field name="don_vi_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_chuc_vu_tree" model="ir.ui.view">
            <field name="name">chuc_vu.tree</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <tree string="Danh sách chức vụ">
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="don_vi_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="chuc_vu_search">
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="don_vi_id"/>
                    
                    <group expand="0" string="Gom nhóm theo">
                        <filter string="Phòng ban / Đơn vị" name="group_by_don_vi" context="{'group_by': 'don_vi_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_chuc_vu" model="ir.actions.act_window">
            <field name="name">Chức vụ</field>
            <field name="res_model">chuc_vu</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="chuc_vu_search"/>
        </record>
    </data>
</odoo>